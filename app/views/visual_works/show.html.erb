<% content_for :title, @visual_work.title %>
<% content_for :meta_description,
   truncate(@visual_work.description.to_s.presence || "Création visuelle — #{@visual_work.title}",
            length: 155, separator: " ") %>
<% if @visual_work.images.attached? %>
  <% content_for :og_image, request.base_url + url_for(@visual_work.images.first) %>
<% end %>

<div data-controller="lightbox">
  <article class="py-5">
    <div class="container">
      <div class="col-lg-8">
        <p class="text-uppercase small letter-spaced text-body-secondary mb-2">
          <%= category_label(@visual_work.category) if @visual_work.category.present? %>
        </p>
        <h1 class="h2 mb-3"><%= @visual_work.title %></h1>
        <% if @visual_work.description.present? %>
          <p class="text-body-secondary mb-4"><%= @visual_work.description %></p>
        <% end %>
      </div>

      <% @visual_work.images.each do |image| %>
        <figure class="my-4">
          <button type="button" class="lightbox-trigger"
                  data-action="lightbox#open"
                  data-src="<%= url_for(image) %>"
                  data-alt="<%= attachment_alt(image, fallback: @visual_work.title) %>"
                  aria-label="Agrandir : <%= attachment_alt(image, fallback: @visual_work.title) %>">
            <%= image_tag image, class: "img-fluid rounded border",
                          alt: attachment_alt(image, fallback: @visual_work.title) %>
          </button>
        </figure>
      <% end %>

      <%= link_to "← Retour à la galerie", visual_works_path, class: "small" %>
    </div>
  </article>

  <%= render "shared/lightbox" %>
</div>
