<% content_for :title, "Galerie" %>
<% content_for :meta_description,
   "Galerie de créations visuelles de Cyprien Darré : identités, concepts, motion design." %>

<section class="screen" aria-label="Galerie visuelle">
  <span class="corner corner-tl mono">Galerie</span>
  <span class="corner corner-tr mono"><%= @visual_works.size %> pièce(s)</span>

  <div class="gallery-head">
    <p class="intro">De la <span class="inflexion">surface</span> au
      <span class="inflexion">fond</span>, en passant par la
      <span class="inflexion">forme</span>.</p>
  </div>

  <% if @categories.many? %>
    <nav class="gallery-filters mono" aria-label="Filtrer par catégorie">
      <%= link_to "Toutes", visual_works_path,
            class: class_names("gallery-filter", "is-active": @current_category.nil?),
            aria: { current: (@current_category.nil? ? "page" : nil) } %>
      <% @categories.each do |cat| %>
        <%= link_to category_label(cat), visual_works_path(categorie: cat),
              class: class_names("gallery-filter", "is-active": @current_category == cat),
              aria: { current: (@current_category == cat ? "page" : nil) } %>
      <% end %>
    </nav>
  <% end %>

  <% if @visual_works.any? %>
    <div class="gallery-grid">
      <% @visual_works.each do |work| %>
        <%= link_to visual_work_path(work), class: "gallery-item" do %>
          <div class="thumb">
            <% if work.images.attached? %>
              <%= image_tag work.images.first, loading: "lazy",
                    alt: attachment_alt(work.images.first, fallback: work.title) %>
            <% else %>
              <span class="ph mono">Visuel</span>
            <% end %>
          </div>
          <div class="cap">
            <span class="title"><%= work.title %></span>
            <% if work.category.present? %>
              <span class="cat mono"><%= category_label(work.category) %></span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p>Rien dans cette catégorie pour l'instant.</p>
  <% end %>
  <%= link_to case_studies_path, class: "cross-row" do %>
    <span class="mono">(←) Études de cas · travaux produit</span>
    <span class="x-arrow" aria-hidden="true">↗</span>
  <% end %>
</section>
