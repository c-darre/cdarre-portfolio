<% content_for :title, "Études de cas — Admin" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Études de cas</h1>
  <%= link_to "+ Nouvelle étude", new_admin_case_study_path, class: "btn btn-dark" %>
</div>

<% if @case_studies.any? %>
  <p class="text-body-secondary small">Glisse les lignes par la poignée pour les réordonner.</p>

  <div class="list-group"
       data-controller="reorder"
       data-reorder-url-value="<%= reorder_admin_case_studies_path %>">
    <% @case_studies.each do |case_study| %>
      <div class="list-group-item d-flex align-items-center gap-3" data-id="<%= case_study.id %>">
        <span class="text-body-tertiary" data-reorder-handle style="cursor: grab;" aria-hidden="true">⠿</span>

        <div class="flex-grow-1">
          <div class="fw-semibold"><%= case_study.title %></div>
          <div class="small text-body-secondary"><%= case_study.role %></div>
        </div>

        <% if case_study.published? %>
          <span class="badge text-bg-success">Publiée</span>
        <% else %>
          <span class="badge text-bg-secondary">Brouillon</span>
        <% end %>

        <%= button_to (case_study.published? ? "Dépublier" : "Publier"),
              toggle_published_admin_case_study_path(case_study),
              method: :patch, class: "btn btn-sm btn-outline-secondary" %>
        <%= link_to "Éditer", edit_admin_case_study_path(case_study), class: "btn btn-sm btn-outline-dark" %>
        <%= button_to "Suppr.", admin_case_study_path(case_study), method: :delete,
              class: "btn btn-sm btn-outline-danger",
              form: { data: { turbo_confirm: "Supprimer « #{case_study.title} » et ses sections ?" } } %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-body-secondary">Aucune étude pour l'instant.</p>
<% end %>
