<% content_for :title, "Galerie — Admin" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Galerie visuelle</h1>
  <%= link_to "+ Nouvelle création", new_admin_visual_work_path, class: "btn btn-dark" %>
</div>

<% if @visual_works.any? %>
  <p class="text-body-secondary small">Glisse par la poignée pour réordonner.</p>
  <div class="list-group"
       data-controller="reorder"
       data-reorder-url-value="<%= reorder_admin_visual_works_path %>">
    <% @visual_works.each do |work| %>
      <div class="list-group-item d-flex align-items-center gap-3" data-id="<%= work.id %>">
        <span class="text-body-tertiary" data-reorder-handle style="cursor: grab;" aria-hidden="true">⠿</span>

        <% if work.images.attached? %>
          <%= image_tag work.images.first, style: "height: 48px; width: 48px; object-fit: cover;", class: "rounded" %>
        <% end %>

        <div class="flex-grow-1">
          <div class="fw-semibold"><%= work.title %></div>
          <div class="small text-body-secondary"><%= category_label(work.category) %></div>
        </div>

        <% if work.published? %>
          <span class="badge text-bg-success">Publiée</span>
        <% else %>
          <span class="badge text-bg-secondary">Brouillon</span>
        <% end %>

        <%= button_to (work.published? ? "Dépublier" : "Publier"),
              toggle_published_admin_visual_work_path(work),
              method: :patch, class: "btn btn-sm btn-outline-secondary" %>
        <%= link_to "Éditer", edit_admin_visual_work_path(work), class: "btn btn-sm btn-outline-dark" %>
        <%= button_to "Suppr.", admin_visual_work_path(work), method: :delete,
              class: "btn btn-sm btn-outline-danger",
              form: { data: { turbo_confirm: "Supprimer « #{work.title} » ?" } } %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-body-secondary">Aucune création pour l'instant.</p>
<% end %>
