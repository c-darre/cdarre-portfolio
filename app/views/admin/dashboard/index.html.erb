<% content_for :title, "Tableau de bord — Admin" %>

<h1 class="h3 mb-4">Tableau de bord</h1>

<div class="row g-3">
  <div class="col-12 col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h2 class="h5 card-title">Études de cas</h2>
        <p class="display-6 mb-1"><%= @case_studies.size %></p>
        <p class="text-body-secondary mb-3"><%= @case_studies.count(&:published?) %> publiée(s)</p>
        <%= link_to "Gérer", admin_case_studies_path, class: "btn btn-outline-dark btn-sm" %>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h2 class="h5 card-title">Galerie</h2>
        <p class="display-6 mb-1"><%= @visual_works.size %></p>
        <p class="text-body-secondary mb-3"><%= @visual_works.count(&:published?) %> publiée(s)</p>
        <%= link_to "Gérer", admin_visual_works_path, class: "btn btn-outline-dark btn-sm" %>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h2 class="h5 card-title">Récompenses</h2>
        <p class="display-6 mb-1"><%= @awards.size %></p>
        <%= link_to "Gérer", admin_awards_path, class: "btn btn-outline-dark btn-sm" %>
      </div>
    </div>
  </div>
</div>
