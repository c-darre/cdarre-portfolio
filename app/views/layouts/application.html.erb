<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= page_title %></title>
    <%= render "shared/meta_tags" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <%# Lien d'évitement : invisible sauf au focus clavier (Tab depuis le haut de page) %>
    <a href="#contenu"
       class="visually-hidden-focusable position-absolute top-0 start-0 m-2 p-2 bg-white border rounded z-3">
      Aller au contenu
    </a>

    <%= render "shared/navbar" %>

    <main id="contenu" class="flex-grow-1">
      <% if notice %>
        <div class="container pt-3"><div class="alert alert-success mb-0" role="alert"><%= notice %></div></div>
      <% end %>
      <% if alert %>
        <div class="container pt-3"><div class="alert alert-danger mb-0" role="alert"><%= alert %></div></div>
      <% end %>
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
