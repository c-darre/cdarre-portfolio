<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= page_title %></title>
    <%= render "shared/meta_tags" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body>
    <a href="#contenu"
       class="visually-hidden-focusable position-absolute top-0 start-0 m-2 p-2 border z-3 mono"
       style="background: #F1EDE4;">
      Aller au contenu
    </a>

    <%# La feuille posée sur la table — tout le site vit dedans. %>
    <div class="sheet">
      <%= render "shared/navbar" %>

      <main id="contenu">
        <% if notice %>
          <div class="container pt-3"><div class="alert alert-success mb-0" role="alert"><%= notice %></div></div>
        <% end %>
        <% if alert %>
          <div class="container pt-3"><div class="alert alert-danger mb-0" role="alert"><%= alert %></div></div>
        <% end %>
        <%= yield %>
      </main>

      <%= render "shared/footer" %>
    </div>
  </body>
</html>
