<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Admin — cdarre.fr" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta name="robots" content="noindex, nofollow">

    <%# Bootstrap + nos tokens (compilés) sur toutes les pages admin %>
    <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <%# CSS de l'éditeur Trix : seulement là où on édite (back-office) %>
    <%= stylesheet_link_tag "trix", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg bg-dark" data-bs-theme="dark">
      <div class="container">
        <%= link_to "Admin · cdarre.fr", admin_root_path, class: "navbar-brand" %>
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#adminNav"
                aria-controls="adminNav" aria-expanded="false" aria-label="Menu">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item"><%= link_to "Études de cas", admin_case_studies_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Galerie",       admin_visual_works_path, class: "nav-link" %></li>
            <li class="nav-item"><%= link_to "Récompenses",   admin_awards_path,       class: "nav-link" %></li>
          </ul>
          <ul class="navbar-nav">
            <li class="nav-item"><%= link_to "Voir le site", root_path, class: "nav-link", target: "_blank", rel: "noopener" %></li>
            <li class="nav-item">
              <%= button_to "Déconnexion", destroy_admin_user_session_path, method: :delete,
                            class: "btn btn-link nav-link", form_class: "d-inline" %>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <% if notice %><div class="alert alert-success" role="alert"><%= notice %></div><% end %>
      <% if alert  %><div class="alert alert-danger"  role="alert"><%= alert %></div><% end %>
      <%= yield %>
    </main>
  </body>
</html>
