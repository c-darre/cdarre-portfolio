<% content_for :title, "Study cases" %>
<% content_for :meta_description,
   "Études de cas produit de Cyprien Darré : refonte UX/UI, design system, " \
   "développement Ruby on Rails et IA appliquée." %>

<section class="screen" aria-label="Études de cas">
  <span class="corner corner-tl mono">Study cases</span>
  <span class="corner corner-tr mono"><%= @case_studies.size %> étude(s)</span>

  <p class="index-intro">Questionner, construire, mesurer.
    Puis <em>recommencer</em>.</p>

  <% if @case_studies.any? %>
    <div class="index">
      <% @case_studies.each_with_index do |case_study, i| %>
        <%= render "index_row", case_study: case_study, row_number: i + 1 %>
      <% end %>
    </div>
  <% else %>
    <p>Les études arrivent : rédaction en cours.</p>
  <% end %>

  <%= link_to visual_works_path, class: "cross-row" do %>
    <span class="mono">(+) Galerie visuelle · identités · concepts · motion</span>
    <span class="x-arrow" aria-hidden="true">↗</span>
  <% end %>
</section>
