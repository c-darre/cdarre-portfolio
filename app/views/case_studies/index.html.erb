<% content_for :title, "Études de cas" %>
<% content_for :meta_description,
   "Études de cas produit de Cyprien Darré : refonte UX/UI, design system, " \
   "développement Ruby on Rails et IA appliquée." %>

<section class="py-5">
  <div class="container">
    <header class="mb-4 col-lg-8">
      <h1 class="h2 mb-2">Études de cas</h1>
      <p class="text-body-secondary mb-0">
        Chaque étude suit la même trame : problème, contraintes, démarche, design,
        technique quand le projet est codé, impact, réflexion.
      </p>
    </header>

    <% if @case_studies.any? %>
      <div class="row g-4">
        <% @case_studies.each do |case_study| %>
          <div class="col-md-6 col-lg-4">
            <%= render "card", case_study: case_study %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-body-secondary">Les études arrivent — rédaction en cours.</p>
    <% end %>
  </div>
</section>
