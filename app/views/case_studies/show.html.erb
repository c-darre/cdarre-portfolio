<% content_for :title, @case_study.title %>
<% content_for :meta_description,
   truncate((@case_study.context.presence || @case_study.subtitle).to_s, length: 155, separator: " ") %>
<% content_for :og_type, "article" %>
<% if @case_study.hero_image.attached? %>
  <% content_for :og_image, request.base_url + url_for(@case_study.hero_image) %>
<% end %>

<div data-controller="lightbox">
  <article>
    <%# ---------- LANDING : visuel + infos structurées ---------- %>
    <header class="cs-landing" aria-label="<%= @case_study.title %>">
      <div class="csl-media">
        <% if @case_study.hero_image.attached? %>
          <%= image_tag @case_study.hero_image, class: "csl-img",
                alt: attachment_alt(@case_study.hero_image, fallback: @case_study.title) %>
        <% else %>
          <span class="csl-ph mono">Visuel · à venir</span>
        <% end %>
      </div>

      <div class="csl-info">
        <p class="eyebrow mono">Study case</p>
        <h1 class="csl-title"><%= @case_study.title %></h1>
        <% if @case_study.subtitle.present? %>
          <p class="csl-sub"><%= @case_study.subtitle %></p>
        <% end %>

        <dl class="csl-meta">
          <% if @case_study.role.present? %>
            <dt class="mono">Rôle</dt><dd><%= @case_study.role %></dd>
          <% end %>
          <% if @case_study.context.present? %>
            <dt class="mono">Contexte</dt><dd><%= @case_study.context %></dd>
          <% end %>
          <% if @case_study.key_metric.present? %>
            <dt class="mono">Repère</dt>
            <dd><span class="dot">●</span> <%= @case_study.key_metric %></dd>
          <% end %>
        </dl>
      </div>
    </header>

    <%# ---------- CORPS : sommaire sticky + sections ---------- %>
    <div class="cs-body" data-controller="toc">
      <% if @sections.any? %>
        <nav class="cs-toc" aria-label="Sommaire">
          <ol>
            <% @sections.each do |section| %>
              <li>
                <a href="#section-<%= section.id %>" class="cs-toc-link"
                   data-toc-target="link">
                  <%= section.heading.presence || section_type_label(section.section_type) %>
                </a>
              </li>
            <% end %>
          </ol>
        </nav>
      <% end %>

      <div class="cs-sections">
        <% @sections.each do |section| %>
          <section id="section-<%= section.id %>" class="cs-section">
            <p class="sec-label mono"><%= section_type_label(section.section_type) %></p>
            <% if section.heading.present? %><h2><%= section.heading %></h2><% end %>

            <div class="case-prose"><%= section.body %></div>

            <% section.images.each do |image| %>
              <figure>
                <button type="button" class="shot"
                        data-action="lightbox#open"
                        data-src="<%= url_for(image) %>"
                        data-alt="<%= attachment_alt(image) %>"
                        aria-label="Agrandir : <%= attachment_alt(image) %>">
                  <%= image_tag image, loading: "lazy", alt: attachment_alt(image) %>
                </button>
              </figure>
            <% end %>
          </section>
        <% end %>
      </div>
    </div>

    <%# ---------- Bas de page ---------- %>
    <nav class="cs-next" aria-label="Navigation entre études">
      <%= link_to "← Back to Study cases", case_studies_path, class: "mono" %>
      <% if @next_case_study %>
        <%= link_to "Next : #{@next_case_study.title} →",
              case_study_path(@next_case_study), class: "next-link" %>
      <% end %>
    </nav>
  </article>

  <%= render "shared/lightbox" %>
</div>
