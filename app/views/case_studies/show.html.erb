<% content_for :title, @case_study.title %>
<% content_for :meta_description,
   truncate((@case_study.context.presence || @case_study.subtitle).to_s, length: 155, separator: " ") %>
<% content_for :og_type, "article" %>
<% if @case_study.hero_image.attached? %>
  <% content_for :og_image, request.base_url + url_for(@case_study.hero_image) %>
<% end %>

<div data-controller="lightbox">
  <article>
    <%# ---------- Hero éditorial ---------- %>
    <header class="case-hero" style="padding-left: clamp(20px,3vw,40px); padding-right: clamp(20px,3vw,40px);">
      <div style="position: relative;">
        <p class="eyebrow mono">Étude de cas</p>
        <h1><%= @case_study.title %></h1>
        <% if @case_study.subtitle.present? %>
          <p class="subtitle"><%= @case_study.subtitle %></p>
        <% end %>

        <dl class="case-meta mono">
          <% if @case_study.role.present? %>
            <dt>Rôle</dt><dd><%= @case_study.role %></dd>
          <% end %>
          <% if @case_study.context.present? %>
            <dt>Contexte</dt><dd><%= @case_study.context %></dd>
          <% end %>
          <% if @case_study.key_metric.present? %>
            <dt>Repère</dt><dd><span class="dot">●</span> <%= @case_study.key_metric %></dd>
          <% end %>
        </dl>

        <% if @case_study.hero_image.attached? %>
          <div class="case-hero-image">
            <%= image_tag @case_study.hero_image,
                  alt: attachment_alt(@case_study.hero_image, fallback: "Visuel principal — #{@case_study.title}") %>
          </div>
        <% end %>
      </div>
    </header>

    <div style="padding-left: clamp(20px,3vw,40px); padding-right: clamp(20px,3vw,40px);">
      <%# ---------- Encart double lecture ---------- %>
      <% paths = reading_paths(@sections) %>
      <% if paths.any? %>
        <aside class="double-reading" aria-label="Deux parcours de lecture">
          <p class="dr-intro mono">Deux angles d'entrée — même étude.</p>
          <div class="dr-cols">
            <% paths.each do |label, sections| %>
              <div>
                <h2><%= label %></h2>
                <ol>
                  <% sections.each do |section| %>
                    <li><a href="#section-<%= section.id %>"><%= section.heading.presence || section_type_label(section.section_type) %></a></li>
                  <% end %>
                </ol>
              </div>
            <% end %>
          </div>
        </aside>
      <% end %>

      <%# ---------- Sections ---------- %>
      <div class="case-body">
        <% @sections.each do |section| %>
          <section id="section-<%= section.id %>" class="case-section">
            <p class="sec-label mono"><%= section_type_label(section.section_type) %></p>
            <% if section.heading.present? %><h2><%= section.heading %></h2><% end %>

            <div class="case-prose"><%= section.body %></div>

            <% section.images.each do |image| %>
              <figure>
                <button type="button" class="shot"
                        data-action="lightbox#open"
                        data-src="<%= url_for(image) %>"
                        data-alt="<%= attachment_alt(image) %>"
                        aria-label="Agrandir : <%= attachment_alt(image) %>">
                  <%= image_tag image, loading: "lazy", alt: attachment_alt(image) %>
                </button>
              </figure>
            <% end %>
          </section>
        <% end %>
      </div>

      <%# ---------- Étude suivante ---------- %>
      <nav class="case-next" aria-label="Navigation entre études">
        <%= link_to "← Tous les projets", case_studies_path, class: "mono" %>
        <% if @next_case_study %>
          <%= link_to "Suivante : #{@next_case_study.title} →",
                case_study_path(@next_case_study), class: "next-link" %>
        <% end %>
      </nav>
    </div>
  </article>

  <%= render "shared/lightbox" %>
</div>
