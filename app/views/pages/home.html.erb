<%# ================= (00) WORDING ================= %>
<section class="screen hero" aria-label="Introduction">
  <p class="kicker mono">Communication · Design · Code</p>
  <h1>Des idées au <em>produit</em> : concevoir, écrire, coder.</h1>

  <span class="vertical mono" aria-hidden="true"><%= profile[:tagline] %></span>
  <a class="scroll-cue mono" href="#profil" aria-label="Défiler vers le profil">↓</a>
</section>

<%# ================= (01) PROFIL ================= %>
<section id="profil" class="screen" aria-label="Profil">
  <span class="corner corner-tl mono">(01) · Profil</span>
  <span class="corner corner-tr mono">2014 → 2026</span>

  <div class="profil-grid">
    <figure class="frame">
      <span class="fig-tl mono" aria-hidden="true">Fig. 01</span>
      <span class="ph mono">Portrait · à venir</span>
      <span class="fig-br mono" aria-hidden="true">3:4</span>
    </figure>

    <div class="profil-text">
      <p class="lead">Transformer des <span class="inflexion nue">idées</span> en
        <span class="inflexion nue">messages clairs</span>, <span class="inflexion">engageants</span>
        et porteurs de <span class="inflexion">sens</span>.</p>

      <p>Une expertise <em>hybride</em>, de la stratégie à la production.
        Dix ans à concevoir des dispositifs de communication et des interfaces
        pour de grands groupes : direction artistique, UX/UI, design system,
        UX writing bilingue, sur des systèmes utilisés par plus de
        100&nbsp;000&nbsp;personnes dans 35&nbsp;pays.</p>

      <p>Renforcée depuis 2026 par l'ingénierie : développement full-stack
        Ruby on Rails et intégration d'IA (LLM, RAG), certifiés par un titre
        RNCP niveau&nbsp;6 et une application déployée.</p>

      <p>L'objectif : des écosystèmes de marque cohérents, des workflows
        fluides entre création, contenu et technique. Allier esthétique et
        <em>performance</em>.</p>

      <div class="facts">
        <div class="fact mono"><span>Stratégie</span><span>Communication · Brand · UX writing FR/EN · Pilotage</span></div>
        <div class="fact mono"><span>Design</span><span>UX/UI · Design system · Direction artistique · Motion</span></div>
        <div class="fact mono"><span>Ingénierie</span><span>Ruby on Rails · JavaScript · SQL · IA (LLM, RAG)</span></div>
      </div>
    </div>
  </div>

  <a class="scroll-cue mono" href="#travaux" aria-label="Défiler vers les travaux">↓</a>
</section>

<%# ================= (02) TRAVAUX ================= %>
<section id="travaux" class="screen screen-negatif" aria-label="Travaux">
  <span class="corner corner-tl mono">(02) · Study cases</span>
  <span class="corner corner-tr mono">Études de cas</span>

  <p class="index-intro">Questionner, construire, mesurer.
    Puis <em>recommencer</em>.</p>

  <% if @case_studies.any? %>
    <div class="index">
      <% @case_studies.each_with_index do |case_study, i| %>
        <%= render "case_studies/index_row", case_study: case_study, row_number: i + 1 %>
      <% end %>
    </div>
  <% else %>
    <p>Les études de cas arrivent : rédaction en cours.</p>
  <% end %>

  <a class="scroll-cue mono" href="#galerie" aria-label="Défiler vers la galerie">↓</a>
</section>

<%# ================= (03) GALERIE ================= %>
<section id="galerie" class="screen-galerie" aria-label="Galerie visuelle"
         data-controller="hscroll">
  <div class="g-pin" data-hscroll-target="pin">
    <span class="corner corner-tl mono">(03) · Galerie</span>
    <span class="corner corner-tr mono">Identités · Concepts · Motion</span>

    <div class="g-track" data-hscroll-target="track" tabindex="0"
         role="region" aria-label="Créations visuelles, défilement horizontal">

      <div class="g-col g-catch">
        <p class="g-catchline">De la <span class="inflexion">surface</span> au
          <span class="inflexion">fond</span>, en passant par la
          <span class="inflexion">forme</span>.</p>
        <div class="g-nav">
          <button type="button" class="g-btn mono" data-action="hscroll#prev" aria-label="Créations précédentes">←</button>
          <button type="button" class="g-btn mono" data-action="hscroll#next" aria-label="Créations suivantes">→</button>
        </div>
      </div>

      <% @visual_works.each do |work| %>
        <%= link_to visual_work_path(work), class: "g-col g-card", data: { hscroll_card: true } do %>
          <% if work.images.attached? %>
            <%= image_tag work.images.first, class: "g-bg", loading: "lazy",
                  alt: attachment_alt(work.images.first, fallback: work.title) %>
          <% end %>
          <div class="g-veil" aria-hidden="true"></div>
          <div class="g-info">
            <span class="g-title"><%= work.title %></span>
            <% if work.tools_list.any? %>
              <span class="g-tools mono"><%= work.tools_list.join(" · ") %></span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# ================= (04) CONTACT ================= %>
<section id="contact" class="screen contact screen-negatif" aria-label="Contact">
  <span class="corner corner-tl mono">(04) · Contact</span>

  <h2 lang="en">Let's <em>connect</em>.</h2>

  <%= render "shared/contact_cta" %>

  <div class="links mono">
    <%= link_to "LinkedIn ↗", profile[:linkedin], target: "_blank", rel: "noopener" %>
    <%= link_to "GitHub ↗", profile[:github], target: "_blank", rel: "noopener" %>
  </div>
</section>
