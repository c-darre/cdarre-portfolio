<% content_for :title, "Contact" %>
<% content_for :meta_description,
   "Contacter Cyprien Darré, Product Designer × Design Engineer. " \
   "Basé à Bordeaux, mobilité France." %>

<section class="screen contact" aria-label="Contact">
  <span class="corner corner-tl mono">Contact</span>

  <h2>Discutons-<em>en</em>.</h2>

  <%= mail_to profile[:email], profile[:email], class: "email" %>

  <div class="links mono">
    <%= link_to "LinkedIn ↗", profile[:linkedin], target: "_blank", rel: "noopener" %>
    <%= link_to "GitHub ↗", profile[:github], target: "_blank", rel: "noopener" %>
    <% if (cv = cv_path_if_available) %>
      <%= link_to "CV (PDF)", cv %>
    <% end %>
  </div>
</section>
