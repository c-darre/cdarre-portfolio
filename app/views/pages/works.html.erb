<% content_for :title, "Travaux" %>
<% content_for :meta_description,
   "Les travaux de Cyprien Darré : study cases produit (UX/UI, design system, code) " \
   "et galerie de créations visuelles (identités, concepts, motion)." %>

<%# Écran de choix : deux lignes uniques (flèche · titre · méta),
    image centrée chevauchée, page SANS scroll (navbar → footer). %>
<section class="works-choice" aria-label="Choisir un univers de travaux">
  <span class="corner corner-tl mono">Travaux</span>

  <div class="wk-media" aria-hidden="true">
    <figure class="wk-figure">
      <span class="ph mono">Visuel · à venir</span>
      <span class="fig-tl mono">Fig. 01</span>
    </figure>
  </div>

  <nav class="wk-list" aria-label="Univers de travaux">
    <%= link_to case_studies_path, class: "wk-row" do %>
      <span class="wk-arrow" aria-hidden="true">→</span>
      <span class="wk-title">Study <em>cases</em></span>
      <span class="wk-sep" aria-hidden="true">/</span>
      <span class="wk-meta mono">Produit · UX/UI · Design system · Code</span>
    <% end %>

    <%= link_to visual_works_path, class: "wk-row" do %>
      <span class="wk-arrow" aria-hidden="true">→</span>
      <span class="wk-title">Galerie <em>visuelle</em></span>
      <span class="wk-sep" aria-hidden="true">/</span>
      <span class="wk-meta mono">Identités · Concepts · Motion</span>
    <% end %>
  </nav>
</section>
