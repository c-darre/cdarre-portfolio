<%# Corps de la section contact, partagé entre la home (03/04) et /contact.
    Composition 1/3 (vidéo chien en boucle) · 2/3 (textes). Fond encre. %>
<div class="ct-grid">
  <div class="ct-media" aria-hidden="true">
    <% if dog_video_available? %>
      <video class="ct-video" autoplay muted loop playsinline
             <%= "poster=#{asset_path('dog-run-poster.png')}" if Rails.root.join('app/assets/images/dog-run-poster.png').exist? %>>
        <% if Rails.root.join('app/assets/images/dog-run.webm').exist? %>
          <source src="<%= asset_path('dog-run.webm') %>" type="video/webm">
        <% end %>
        <% if Rails.root.join('app/assets/images/dog-run.mp4').exist? %>
          <source src="<%= asset_path('dog-run.mp4') %>" type="video/mp4">
        <% end %>
      </video>
    <% else %>
      <span class="ct-ph mono">Vidéo · à venir</span>
    <% end %>
  </div>

  <div class="ct-text">
    <h2 lang="en">Let's <em>connect</em>.</h2>

    <%= render "shared/contact_cta" %>

    <div class="links mono">
      <%= link_to "LinkedIn ↗", profile[:linkedin], target: "_blank", rel: "noopener" %>
      <%= link_to "GitHub ↗", profile[:github], target: "_blank", rel: "noopener" %>
      <% if (cv = cv_path_if_available) %>
        <%= link_to "CV (PDF)", cv %>
      <% end %>
    </div>
  </div>
</div>
