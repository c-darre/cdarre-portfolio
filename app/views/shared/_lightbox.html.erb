<%# Dialog natif : focus piégé, Esc et rôle modal fournis par le navigateur. %>
<dialog class="lightbox-dialog"
        data-lightbox-target="dialog"
        data-action="click->lightbox#backdropClose">
  <button type="button" class="btn-close btn-close-white lightbox-close"
          data-action="lightbox#close" aria-label="Fermer l'aperçu"></button>
  <img data-lightbox-target="image" src="" alt="">
</dialog>
